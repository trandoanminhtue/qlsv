generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Class {
  id        Int      @id @default(autoincrement())
  name      String
  students  String[] // Phải là String[] để dùng được hàm push và filter
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}